# Frontend build-time configuration (Vite). Copy to `.env.local` to override.
# These are read at BUILD time and baked into the bundle.

# Base URL the SPA uses for API calls.
# Leave empty to use "/api" — served through the Vite dev proxy locally and the
# nginx proxy in the Docker image (both same-origin, no CORS needed).
# Set an absolute URL only when the API is deployed on a different origin, e.g.:
#   VITE_API_URL=https://api.fraternityos.example.com
VITE_API_URL=
