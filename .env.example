# ---------------------------------------------------------------------------
# Copy to `.env` and adjust before running `docker compose up`.
# docker-compose reads this file automatically. Never commit a real `.env`.
# Every variable has a safe local default in docker-compose.yml, so an empty
# .env still boots the stack; override the values below for production.
# ---------------------------------------------------------------------------

# --- Spring profile ---------------------------------------------------------
# `prod` reads all config from env (application-prod.yml) and fails fast if a
# required value is missing. Use `default` only for the non-containerized dev run.
SPRING_PROFILES_ACTIVE=prod

# --- Database ---------------------------------------------------------------
# Credentials for the bundled Postgres container.
POSTGRES_DB=fraternityos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# The backend datasource. Points at the compose `postgres` service by default;
# set to an external database URL in production.
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/fraternityos
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# --- Security ---------------------------------------------------------------
# JWT signing secret — MUST be a strong, unique value of at least 32 bytes.
# Generate one, e.g.:  openssl rand -base64 48
JWT_SECRET=change-me-dev-secret-at-least-32-bytes-long-000
# Token lifetime in milliseconds (default 24h).
JWT_EXPIRATION_MS=86400000

# --- CORS -------------------------------------------------------------------
# Comma-separated list of allowed browser origins for cross-origin API calls.
# Leave EMPTY when the SPA is served same-origin through the nginx/dev proxy.
# Never use "*" in production. Example: https://app.example.com
CORS_ALLOWED_ORIGINS=

# --- Storage ----------------------------------------------------------------
# Directory (inside the backend container) for uploaded statement attachments.
FILE_STORAGE_DIR=/app/uploads

# --- Frontend (build-time) --------------------------------------------------
# Base URL the SPA calls. Empty => "/api" (proxied by nginx). Set an absolute
# URL only for a cross-origin API deployment. Baked in at image build time.
VITE_API_URL=
# Host port the frontend is published on.
FRONTEND_PORT=5173

# --- JVM (optional) ---------------------------------------------------------
# Extra JVM flags for the backend, e.g. -XX:MaxRAMPercentage=75
JAVA_OPTS=
